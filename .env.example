# Copie este arquivo para .env e preencha com as suas credenciais da Unipile.
# Você pega esses 3 valores no painel da Unipile (https://app.unipile.com).

# DSN da sua conta + /api/v1 no final. Ex: https://apiXX.unipile.com:PORTA/api/v1
UNIPILE_BASE_URL=

# Sua chave de API (Access Token) da Unipile
UNIPILE_API_KEY=

# ID da conta de LinkedIn conectada na Unipile (Accounts > sua conta)
UNIPILE_ACCOUNT_ID=
